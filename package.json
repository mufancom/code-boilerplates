{
  "name": "@mufan/code-boilerplates",
  "version": "0.0.0",
  "description": "Code boilerplates for Mufan",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mufancom/code-boilerplates.git"
  },
  "author": "Chengdu Mufan Technology Co., Ltd.",
  "license": "MIT",
  "type": "module",
  "exports": {
    "./general": {
      "types": "./general/bld/library/index.d.ts",
      "default": "./general/bld/library/index.js"
    },
    "./typescript": {
      "types": "./typescript/bld/library/index.d.ts",
      "default": "./typescript/bld/library/index.js"
    }
  },
  "packageManager": "yarn@1.22.22",
  "scripts": {
    "3": "yarn && yarn-deduplicate && yarn",
    "build": "rimraf --glob */bld && tsc --build",
    "lint": "eslint --no-error-on-unmatched-pattern --report-unused-disable-directives .",
    "lint-prettier": "prettier --check .",
    "test": "npm run lint-prettier && npm run build && npm run lint"
  },
  "dependencies": {
    "@magicspace/core": "^0.3.7",
    "@magicspace/utils": "^0.3.4",
    "lodash": "^4.18.1",
    "npm-which": "^3.0.1",
    "prettier": "^3.8.1",
    "tslang": "^0.1.27",
    "tslib": "^2.8.1",
    "typescript": "^6.0.2"
  },
  "devDependencies": {
    "@mufan/eslint-plugin": "^0.3.0",
    "@types/lodash": "^4.17.24",
    "@types/node": "^25.5.2",
    "eslint": "^10.2.0",
    "rimraf": "^6.1.3",
    "yarn-deduplicate": "^6.0.2"
  }
}
